# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Kokoro TTS voice (local, no API key needed — defaults to am_fenrir)
# Male American: am_fenrir, am_michael, am_puck | British: bm_george, bm_fable
# Female American: af_heart, af_bella | British: bf_emma, bf_isabella
# KOKORO_VOICE=am_fenrir

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Outlook calendar accounts to read (comma-separated)
# If not set, JARVIS reads your default Outlook calendar
# CALENDAR_ACCOUNTS=you@outlook.com,work@company.com
