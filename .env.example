# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: edge-tts voice (free Microsoft neural TTS, no API key needed)
# Male British: en-GB-RyanNeural, en-GB-ThomasNeural
# Male American: en-US-GuyNeural, en-US-ChristopherNeural
# EDGE_TTS_VOICE=en-GB-RyanNeural

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Outlook calendar accounts to read (comma-separated)
# If not set, JARVIS reads your default Outlook calendar
# CALENDAR_ACCOUNTS=you@outlook.com,work@company.com
